{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "everything-imu",
  "version": "1.0.6",
  "identifier": "dev.matiaspalmac.everything-imu",
  "build": {
    "beforeDevCommand": "pnpm --filter @everything-imu/ui dev",
    "beforeBuildCommand": "pnpm --filter @everything-imu/ui build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "everything-imu",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src ipc: http://ipc.localhost",
      "devCsp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src ipc: http://ipc.localhost ws://127.0.0.1:5173 http://127.0.0.1:5173"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "createUpdaterArtifacts": true,
    "linux": {
      "deb": {
        "depends": ["libayatana-appindicator3-1"]
      },
      "appimage": {
        "files": {
          "/usr/lib/libayatana-appindicator3.so.1": "/usr/lib/x86_64-linux-gnu/libayatana-appindicator3.so.1",
          "/usr/lib/libdbusmenu-glib.so.4": "/usr/lib/x86_64-linux-gnu/libdbusmenu-glib.so.4",
          "/usr/lib/libdbusmenu-gtk3.so.4": "/usr/lib/x86_64-linux-gnu/libdbusmenu-gtk3.so.4"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyMURFNTdENjc2NkIyRUUKUldUdXNtWm5mZVVkY3BuZWFjMU9uNTRjM25nZXpkVUMwbW8wYmdMK1l3VExEM2VxMDRNeUFENE0K",
      "endpoints": [
        "https://github.com/matiaspalmac/everything-imu/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
